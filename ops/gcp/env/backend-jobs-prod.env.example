# Cloud Run jobs env for production scheduled jobs.
# Copy to backend-jobs-prod.env and replace the placeholder values before deploy.

SERVER_NAME="numerbay.ai"
SERVER_HOST="https://numerbay.ai"
PROJECT_NAME="NumerBay"
FIRST_SUPERUSER="admin@numerbay.ai"

SECRET_KEY="REPLACE_WITH_APP_SECRET_KEY"
FIRST_SUPERUSER_PASSWORD="REPLACE_WITH_APP_FIRST_SUPERUSER_PASSWORD"

POSTGRES_SERVER="REPLACE_WITH_CLOUD_SQL_PRIVATE_IP"
POSTGRES_USER="REPLACE_WITH_APP_POSTGRES_USER"
POSTGRES_PASSWORD="REPLACE_WITH_APP_POSTGRES_PASSWORD"
POSTGRES_DB="REPLACE_WITH_APP_POSTGRES_DB"

SMTP_TLS="True"
SMTP_PORT="587"
SMTP_HOST=""
SMTP_USER=""
SMTP_PASSWORD=""
MAILGUN_DOMAIN_NAME="numerbay.ai"
MAILGUN_API_KEY="REPLACE_WITH_APP_MAILGUN_API_KEY"
EMAILS_FROM_EMAIL="admin@numerbay.ai"

GCP_PROJECT="numerbay"
GCP_STORAGE_BUCKET="storage.numerbay.ai"
# Keep the single quotes and paste the GitHub secret value as one JSON string.
GCP_SERVICE_ACCOUNT_INFO='REPLACE_WITH_APP_GCP_SERVICE_ACCOUNT_INFO_JSON'
GCP_WEBHOOK_FUNCTION="REPLACE_WITH_APP_GCP_WEBHOOK_FUNCTION"

INFURA_PROJECT_ID="REPLACE_WITH_APP_INFURA_PROJECT_ID"
SENTRY_DSN="REPLACE_WITH_APP_SENTRY_DSN"
WEBHOOK_ENABLED="True"

# These do not affect direct-run Cloud Run jobs, but keeping them explicit avoids
# accidental owner flips if this file is reused elsewhere.
SCHEDULER_OWNER_GLOBALS_STATS="celery"
SCHEDULER_OWNER_STAKE_SNAPSHOTS="celery"
SCHEDULER_OWNER_PRODUCT_SALES_STATS="celery"
SCHEDULER_OWNER_POLLS="celery"
SCHEDULER_OWNER_PRUNE_STORAGE="celery"
SCHEDULER_OWNER_ARTIFACT_REMINDERS="celery"
