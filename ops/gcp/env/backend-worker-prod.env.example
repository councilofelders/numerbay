SCHEDULER_OWNER_GLOBALS_STATS="celery"
SCHEDULER_OWNER_STAKE_SNAPSHOTS="celery"
SCHEDULER_OWNER_PRODUCT_SALES_STATS="celery"
SCHEDULER_OWNER_POLLS="celery"
SCHEDULER_OWNER_PRUNE_STORAGE="celery"
SCHEDULER_OWNER_ARTIFACT_REMINDERS="celery"

GCP_TASKS_LOCATION="us-central1"
GCP_TASKS_QUEUE_NOTIFICATIONS="numerbay-queue-notifications"
GCP_TASKS_QUEUE_WEBHOOKS="numerbay-queue-webhooks"
GCP_TASKS_QUEUE_PAYMENTS="numerbay-queue-payments"
GCP_TASKS_QUEUE_SUBMISSIONS="numerbay-queue-submissions"

ASYNC_WORKER_DISPATCH_URL="REPLACE_WITH_NUMERBAY_WORKER_DISPATCH_URL"
ASYNC_WORKER_DISPATCH_TOKEN="REPLACE_WITH_ASYNC_WORKER_DISPATCH_TOKEN"
